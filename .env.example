# ========== AI APIs ==========

# Anthropic Claude API (Agent 核心依赖)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API (VLM 图像分析)
GEMINI_API_KEY=your_gemini_api_key_here

# Mnemonic Director Service (可选 - 记忆检索服务)
# MNEMONIC_SERVICE_URL=http://localhost:5000

# ========== 配置路径 ==========
STRATEGY_CONFIG_PATH=./config/strategies
PROMPT_CONFIG_PATH=./config/prompts
DEFAULT_STRATEGY=default

# ========== 可选服务 ==========
# ai-moments 服务 (可选)
# USE_AI_MOMENTS=false
# AI_MOMENTS_API=http://localhost:8001
# AI_MOMENTS_TIMEOUT=120000

# ========== Memory Select 服务 ==========
# USE_MEMORY_SELECT=false
# MEMORY_SELECT_API=https://memory-select-production.up.railway.app
# MEMORY_SELECT_TIMEOUT=30000

# MongoDB (可选 - 用于持久化存储)
# MONGODB_URI=mongodb://localhost:27017/pixelbeat
